ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Store backend: pick ONE with STORE_BACKEND, then fill in only that
# backend's vars below. The other backend's vars are ignored, safe to leave
# blank. See agent/store/redis_client.py for the selection logic.
STORE_BACKEND=memory
# memory        — zero setup, default. Data lives in the process and resets
#                 on restart. Fine for local dev; NOT for a deployed app
#                 with real accounts (see docs/DEPLOYMENT.md).
# redis_cloud   — fill in REDIS_URL only.
# upstash       — fill in all four UPSTASH_* vars only.

# redis_cloud: NEVER put a real value here in a committed file — this
# connection string can read AND write every estate, including uploaded
# documents' actual file bytes (stored as base64 blobs), for anyone who
# finds it. Keep it only in your local, gitignored agent/.env. Must be
# Redis 8+ for Vector Sets (VADD/VSIM/VDIM) — an older/incompatible Redis
# will still store estate data fine, but chat retrieval and per-document
# search silently stop working (see docs/database.md).
REDIS_URL=

# upstash: same "never commit a real value" warning as REDIS_URL above.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
UPSTASH_VECTOR_REST_URL=
UPSTASH_VECTOR_REST_TOKEN=

PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006/v1/traces
PHOENIX_BASE_URL=http://localhost:6006
PHOENIX_PROJECT_NAME=probatepilot-agent
PHOENIX_API_KEY=
PHOENIX_EVAL_PROVIDER=anthropic
PHOENIX_EVAL_MODEL=claude-sonnet-4-6
PHOENIX_CAPTURE_EVAL_CONTEXT=false
# Keep true for the demo so Phoenix shows prompts, tool calls, and completions.
# Set false in deployments where estate content must be redacted.
PHOENIX_CAPTURE_LLM_CONTENT=true
OTEL_SERVICE_NAME=probatepilot-agent
APP_ENV=development

# Email notifications (Resend). Both must be set for "Send weekly recap" /
# "Email these alerts" to actually deliver — otherwise the UI shows a preview.
# Get a free key at https://resend.com/api-keys
RESEND_API_KEY=
# Verified sender. Use onboarding@resend.dev to send without verifying a domain.
EMAIL_FROM=onboarding@resend.dev
# Optional: redirect every notification here regardless of the executor's address.
# Resend test mode only delivers to your own account email until you verify a
# domain — set this to that address to receive the demo emails.
NOTIFY_OVERRIDE_RECIPIENT=
